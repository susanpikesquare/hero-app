{
  "expo": {
    "name": "Home Hero",
    "slug": "home-hero",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "homehero",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "co.pikesquare.homehero",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Home Hero needs the camera so kids can submit a photo of their finished chore.",
        "NSPhotoLibraryUsageDescription": "Home Hero needs your photo library so kids can choose a finished-chore photo to submit.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "co.pikesquare.homehero",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#5E7A5C",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Home Hero needs your photo library so kids can choose a finished-chore photo to submit.",
          "cameraPermission": "Home Hero needs the camera so kids can submit a photo of their finished chore."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "c57d21d9-4a51-4d3d-b657-2dd4cb045b5a"
      },
      "router": {}
    },
    "owner": "susanpikesquare",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c57d21d9-4a51-4d3d-b657-2dd4cb045b5a"
    }
  }
}
