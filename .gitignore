# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

example

# Native iOS — we commit the Xcode project (ios/HomeHero.xcodeproj,
# ios/HomeHero.xcworkspace, ios/Podfile etc.) so `git pull` is enough
# to be ready to build. But we gitignore the dependency + build output
# directories that get regenerated locally.
/ios/Pods/
/ios/build/
/ios/DerivedData/
/ios/*.xcodeproj/xcuserdata/
/ios/*.xcworkspace/xcuserdata/

# Android still regenerated by `expo prebuild` per change.
/android

# Vercel
.vercel
dist

# Claude Code (local-only; share settings.json + launch.json across the team)
.claude/settings.local.json

# Fastlane (local iOS release pipeline)
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
fastlane/*.cer
fastlane/*.p12

# Local archive output from `fastlane build` / `fastlane beta`
build/*.ipa
build/*.xcarchive
build/*.app.dSYM.zip
